# API base (must end with /api for this app)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Stripe publishable key (safe in browser; must match backend STRIPE_PUBLISHABLE_KEY)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set false to hide/disable top-up UI temporarily (e.g. production launch phase).
# NEXT_PUBLIC_WALLET_TOPUP_ENABLED=true
# Social login client IDs are provided by backend /api/auth/social-config.

# WebSocket (Socket.IO) — same host as backend
NEXT_PUBLIC_WS_URL=http://localhost:5000

# Message notifications: browser will prompt on dashboard; alerts when tab is in background (browser open).
# HTTPS required in production for Notification API + microphone (voice notes).

# Optional: override STUN/TURN as JSON (otherwise use defaults + GET /api/webrtc/ice-config)
# NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]

# Dialer: allow starting a call when wallet balance is 0 (staging only; production should require top-up).
# NEXT_PUBLIC_CALL_ALLOW_ZERO_BALANCE=true

# Hero page “Download App” buttons (full store URLs). If unset, buttons stay on # until you add links.
# NEXT_PUBLIC_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=...
# NEXT_PUBLIC_IOS_STORE_URL=https://apps.apple.com/app/id...
